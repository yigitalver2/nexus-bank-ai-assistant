# ─────────────────────────────────────────────
# Nexus Bank AI Assistant — Environment Variables
# Copy this file to `.env` and fill in real values.
# Never commit `.env` to git.
# ─────────────────────────────────────────────


# ─────────────────────────────────────────────
# Backend — Application
# ─────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO


# ─────────────────────────────────────────────
# Backend — PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_USER=nexus
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=nexus_bank
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full SQLAlchemy URL — overrides discrete vars above if set.
DATABASE_URL=postgresql+psycopg://nexus:change_me_in_production@postgres:5432/nexus_bank


# ─────────────────────────────────────────────
# Backend — JWT Auth
# ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_64_char_hex_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8


# ─────────────────────────────────────────────
# Backend — OpenAI
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_REALTIME_VOICE=alloy


# ─────────────────────────────────────────────
# Backend — Chroma (embedded vector store)
# ─────────────────────────────────────────────
CHROMA_PERSIST_DIR=/app/chroma_data
CHROMA_COLLECTION=nexus_bank_kb


# ─────────────────────────────────────────────
# Backend — CORS
# ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000


# ─────────────────────────────────────────────
# Frontend (Vite — only VITE_* vars are exposed to the browser)
# ─────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
